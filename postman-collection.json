{
  "info": {
    "name": "Ecommerce Tejidos API",
    "description": "Endpoints completos del ecommerce.\n\n1️⃣ Ejecutar POST /auth/login con las creds de prueba (cliente@test.com / test1234) para guardar el JWT automáticamente en la variable {{jwt_token}}.\n\n2️⃣ Los demás endpoints usan {{jwt_token}} en el header Authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwt_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🟢 Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.token) {",
                  "    pm.collectionVariables.set('jwt_token', resp.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Nuevo Usuario\",\n  \"email\": \"nuevo@test.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (usuario de prueba)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.token) {",
                  "    pm.collectionVariables.set('jwt_token', resp.token);",
                  "    console.log('JWT guardado: ' + resp.token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@test.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "🟢 Catálogo (público)",
      "item": [
        {
          "name": "Listar categorías (árbol)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/categorias",
              "host": ["{{base_url}}"],
              "path": ["api", "categorias"]
            }
          }
        },
        {
          "name": "Listar productos (con paginación)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/productos?page=0&size=10&sort=nombre,asc",
              "host": ["{{base_url}}"],
              "path": ["api", "productos"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"},
                {"key": "sort", "value": "nombre,asc"}
              ]
            }
          }
        },
        {
          "name": "Listar productos (filtrar por nombre)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/productos?nombre=bufanda&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "productos"],
              "query": [
                {"key": "nombre", "value": "bufanda"},
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Listar productos (filtrar por categoría)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/productos?categoriaId=1&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "productos"],
              "query": [
                {"key": "categoriaId", "value": "1"},
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Listar productos (rango de precio)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/productos?precioMin=1000&precioMax=2000&page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "productos"],
              "query": [
                {"key": "precioMin", "value": "1000"},
                {"key": "precioMax", "value": "2000"},
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Detalle de producto (con variantes e imágenes)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/productos/1",
              "host": ["{{base_url}}"],
              "path": ["api", "productos", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "🔒 Carrito (requiere JWT)",
      "item": [
        {
          "name": "Obtener carrito",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/carrito",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito"]
            }
          }
        },
        {
          "name": "Agregar item al carrito",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"varianteProductoId\": 1,\n  \"cantidad\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/carrito/items",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito", "items"]
            }
          }
        },
        {
          "name": "Agregar otro item (bufanda azul L)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"varianteProductoId\": 4,\n  \"cantidad\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/carrito/items",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito", "items"]
            }
          }
        },
        {
          "name": "Agregar osito tejido",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"varianteProductoId\": 11,\n  \"cantidad\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/carrito/items",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito", "items"]
            }
          }
        },
        {
          "name": "Actualizar cantidad de item",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/carrito/items/1?cantidad=3",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito", "items", "1"],
              "query": [{"key": "cantidad", "value": "3"}]
            }
          }
        },
        {
          "name": "Eliminar item del carrito",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/carrito/items/1",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito", "items", "1"]
            }
          }
        },
        {
          "name": "Vaciar carrito",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/carrito",
              "host": ["{{base_url}}"],
              "path": ["api", "carrito"]
            }
          }
        }
      ]
    },
    {
      "name": "🔒 Checkout y Pedidos (requiere JWT)",
      "item": [
        {
          "name": "Checkout (crear pedido desde carrito)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"direccionEnvioId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/checkout",
              "host": ["{{base_url}}"],
              "path": ["api", "checkout"]
            }
          }
        },
        {
          "name": "Listar mis pedidos",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/pedidos?page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "pedidos"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Detalle de pedido",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/pedidos/1",
              "host": ["{{base_url}}"],
              "path": ["api", "pedidos", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "📖 Swagger / Actuator",
      "item": [
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/swagger-ui.html",
              "host": ["{{base_url}}"],
              "path": ["swagger-ui.html"]
            }
          }
        },
        {
          "name": "API Docs (JSON)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v3/api-docs",
              "host": ["{{base_url}}"],
              "path": ["v3/api-docs"]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/actuator/health",
              "host": ["{{base_url}}"],
              "path": ["actuator", "health"]
            }
          }
        }
      ]
    }
  ]
}
